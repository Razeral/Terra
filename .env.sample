# Terra — Multi-Agent Orchestrator
# Copy to .env and fill in values

# Max concurrent agents (default: 8)
TERRA_MAX_AGENTS=8

# Model for the Mayor session (default: opus)
# Options: opus, sonnet, haiku
TERRA_MODEL=opus

# --- Optional: Telegram Notifications ---
# If set, the watchdog and agent-complete scripts will send alerts via Telegram.
# Leave blank to disable notifications.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_USER_ID=
